{
    "version": "0.2.0",
    "configurations": [

        /* =====================================================
           1️⃣ Debug using Integrated Terminal (Recommended)
           ===================================================== */
        {
            "name": "Debug C (Integrated Terminal)",
            "type": "cppdbg",
            "request": "launch",

            "program": "${workspaceFolder}/Embedded_Command_Processor/build/app.exe",
            "args": [],
            "cwd": "${workspaceFolder}/Embedded_Command_Processor",

            "stopAtEntry": true,

            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",

            /* 🔑 stdin works here */
            "console": "integratedTerminal",
            "externalConsole": false,

            "preLaunchTask": "make",

            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },

        /* =====================================================
           2️⃣ Debug using External Terminal (Most reliable)
           ===================================================== */
        {
            "name": "Debug C (External Terminal)",
            "type": "cppdbg",
            "request": "launch",

            "program": "${workspaceFolder}/Embedded_Command_Processor/build/app.exe",
            "args": [],
            "cwd": "${workspaceFolder}/Embedded_Command_Processor",

            "stopAtEntry": false,

            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",

            /* 🔥 Separate cmd window */
            "externalConsole": true,

            "preLaunchTask": "make"
        }
    ]
}
